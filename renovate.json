{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Invidious images use date-sha tags (2026.07.14-e5bde4b); parse as calver so updates are detected, and automerge them",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "quay.io/invidious/invidious",
        "quay.io/invidious/invidious-companion"
      ],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d{2})\\.(?<patch>\\d{2})(?:-[a-f0-9]+)?$",
      "automerge": true
    }
  ],
  "flux": {
    "managerFilePatterns": [
      "/k8s/.+\\.yaml$/",
      "/apps/.+\\.yaml$/",
      "/infrastructure/.+\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/k8s/.+\\.yaml$/",
      "/apps/.+\\.yaml$/",
      "/infrastructure/.+\\.yaml$/"
    ],
    "packageRules": [
      {
        "matchUpdateTypes": [
          "minor",
          "patch"
        ],
        "matchCurrentVersion": "!/^0/",
        "automerge": true
      }
    ]
  }
}

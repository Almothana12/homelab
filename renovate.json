{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Invidious tracks rolling tags (master/latest) pinned by digest; take every new build and automerge it",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "quay.io/invidious/invidious",
        "quay.io/invidious/invidious-companion"
      ],
      "automerge": true,
      "ignoreTests": true
    }
  ],
  "flux": {
    "managerFilePatterns": [
      "/k8s/.+\\.yaml$/",
      "/apps/.+\\.yaml$/",
      "/infrastructure/.+\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/k8s/.+\\.yaml$/",
      "/apps/.+\\.yaml$/",
      "/infrastructure/.+\\.yaml$/"
    ],
    "packageRules": [
      {
        "matchUpdateTypes": [
          "minor",
          "patch"
        ],
        "matchCurrentVersion": "!/^0/",
        "automerge": true
      }
    ]
  }
}
